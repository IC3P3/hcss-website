IMAGE_NAME=git.eiflerstrom.de/ic3p3/hcss-website
IMAGE_TAG=dev            # dev / prod
APP_PORT=3000
DATA_DIR=/srv/hcss/data  # holds the sqlite DB and uploads

HOST_URL=https://hcss.example.de
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

LOG_LEVEL=info           # winston level: error / warn / info / debug

# Optional analytics (compose profile "analytics"). Leave PUBLIC_UMAMI_* empty
# to omit the tracking script from the site.
UMAMI_PORT=3001
UMAMI_DB_DIR=/srv/hcss/umami-db
UMAMI_DB_PASSWORD=change-me
UMAMI_APP_SECRET=change-me-random-string
PUBLIC_UMAMI_SRC=                          # e.g. https://stats.example.de/script.js
PUBLIC_UMAMI_WEBSITE_ID=                   # website ID from the Umami dashboard
