# SQLite database file path (relative or absolute)
DATABASE_URL=local.db

# Public base URL, used to build sitemap.xml and robots.txt
HOST_URL=http://localhost:5173

# Directory where uploaded media is stored
UPLOAD_PATH=upload

# Admin account created by the seed scripts.
# ADMIN_PASSWORD is required by the production seed (scripts/seed-production.ts).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# winston log level: error / warn / info / debug
LOG_LEVEL=info

# Optional Umami analytics. Leave empty to omit the tracking script.
PUBLIC_UMAMI_SRC=
PUBLIC_UMAMI_WEBSITE_ID=
